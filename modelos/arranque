import modelos.engine.*
import modelos.usuario.*

import com.fasterxml.jackson.core.*;
import com.fasterxml.jackson.databind.*;

public class arranque {
    private static final ObjectMapper M = new ObjectMapper();

    public static void main(String[] args) throws Exception {
        // 1) Cargar personas desde data/personas/*.json
        Path personasDir = Paths.get("data/personas");
        if (!Files.exists(personasDir) || !Files.isDirectory(personasDir)) {
            System.err.println("Crea carpeta data/personas con JSONs de Persona.");
            return;
        }
        List<Persona> personas = new ArrayList<>();
        try (DirectoryStream<Path> ds = Files.newDirectoryStream(personasDir, "*.json")) {
            for (Path p : ds) {
                Persona per = M.readValue(p.toFile(), Persona.class);
                personas.add(per);
            }
        }
        System.out.println("Cargadas " + personas.size() + " personas.");

        // 2) Construir estructuras globales
        Registry registry = new Registry();
        registry.buildFrom(personas);

        LevelIndex levelIndex = new LevelIndex();
        levelIndex.buildFrom(personas);

        // social links
        Path socialPath = Paths.get("data/social_links.json");
        SocialGraph socialGraph = new SocialGraph();
        if (Files.exists(socialPath)) {
            JsonNode root = M.readTree(socialPath.toFile());
            List<NPC> npcs = M.convertValue(root.get("npcs"), new TypeReference<List<NPC>>() {});
            socialGraph.buildFrom(npcs);
        }

        FusionIndex fusionIndex = new FusionIndex();
        fusionIndex.buildFrom(personas);

        // 3) UserManager
        UserManager um = new UserManager();

        // DEMO: crear usuario si no existe
        String demoUser = "álvaro";
        if (!um.usernameExists(demoUser)) {
            um.createUser(demoUser, "password123");
            System.out.println("Usuario demo creado: " + demoUser);
        }
        User u = um.getUser(demoUser);

        // 4) Crear UserView (team capacity 12)
        UserView uv = new UserView(u, registry, fusionIndex, socialGraph, levelIndex, 12);

        // DEMO de operaciones solicitadas:
        System.out.println("\n--- Registro impreso (con owned) ---");
        uv.printRegistryWithOwned();

        System.out.println("\n--- Añadir persona registrada al equipo (si hay espacio) ---");
        // marcar Orpheus como owned para demo
        u.owned.add("Orpheus");
        boolean added = uv.addRegisteredToTeam("Orpheus");
        System.out.println("Añadido Orpheus al equipo: " + added);
        uv.team.printTeam();

        System.out.println("\n--- Liberar persona del equipo ---");
        boolean released = uv.releaseFromTeam("Orpheus");
        System.out.println("Liberado Orpheus: " + released);
        uv.team.printTeam();

        System.out.println("\n--- Incrementar social link y auto registrar desbloqueos ---");
        List<String> newly = uv.increaseSocialLinkAndHandleUnlock("Yukari", 10, um);
        System.out.println("Nuevas personas registradas por Yukari: " + newly);

        System.out.println("\n--- Fusionar dos personas del equipo (demo) ---");
        // Para demo, asegurarse de tener dos miembros en equipo que puedan fusionar
        // (esto depende de tus JSONs y fusionIndex)
        // uv.fuseAndReplace("Orpheus", "Pixie", um);

        // Guardar usuario al final
        um.saveUser(u);
        System.out.println("Demo finalizado. Usuario guardado.");
    }
}